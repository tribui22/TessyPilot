	$testcase 2 {
		$name "IcuHdl_TimerNoti_LowPulseMeasure. Test case 02"
		$specification """
			[Test Goal]
				Verify that IcuHdl_TimerNoti_LowPulseMeasure correctly takes the TRUE branch: DioDrv_Level_High == IcuHdl_DigitGet() TRUE (high signal detected), PULSE_MAX != lowPulse TRUE, highPulse != 0 TRUE
			[Precondition]
				Set input variables so that the following condition evaluates to TRUE: DioDrv_Level_High == IcuHdl_DigitGet() TRUE (high signal detected), PULSE_MAX != lowPulse TRUE, highPulse != 0 TRUE
			[Test Description]
				Execute IcuHdl_TimerNoti_LowPulseMeasure() targeting: DioDrv_Level_High == IcuHdl_DigitGet() TRUE (high signal detected), PULSE_MAX != lowPulse TRUE, highPulse != 0 TRUE. Expected outcome: `DioDrv_Level_High == IcuHdl_DigitGet(...)` TRUE branch.
			[Expected Result]
				Output match expected results which specified in test steps
				- Condition evaluates to TRUE (Target: `DioDrv_Level_High == IcuHdl_DigitGet(...)` TRUE branch)
				- Correct branch statements execute (C0 + C1 coverage met)
				- Function completes without errors or unexpected side-effects
			[Post Condition]
				None
			[Test Type]
				Tessy
			[Priority]
				Medium
		"""
		$description """
			DioDrv_Level_High == IcuHdl_DigitGet() TRUE (high signal detected), PULSE_MAX != lowPulse TRUE, highPulse != 0 TRUE
		"""

		$teststep 2.1 {
			$name "DioDrv_Level_High == IcuHdl_DigitGet() TRUE (high signal detected), PULSE_MAX != lowPulse TRUE, highPulse != 0 TRUE"
			$stubfunctions {
				unsigned char IcuHdl_DigitGet(unsigned char Port, unsigned char Pin) '''
					return 1;
				'''
			}
			$inputs {
				IcuHdl_PulseDataBak_st[0] {
					highPulse_u16 = 0
					lowPulse_u16 = 0
				}
				locHdl_u8 = 0
			}
			$outputs {
				IcuHdl_MeasureTimeOutCnt_u8[0] = 0
				IcuHdl_MeasureState_en[0] = IcuHdl_InitMeasure
				IcuHdl_PulseData_st[0] {
					highPulse_u16 = 0
					lowPulse_u16 = 0
				}
				IcuHdl_PulseData_st[1] {
					highPulse_u16 = 0
					lowPulse_u16 = 0
				}
				IcuHdl_PulseData_st[2] {
					highPulse_u16 = 0
					lowPulse_u16 = 0
				}
				IcuHdl_PulseDataBak_st[0] {
					highPulse_u16 = 0
					lowPulse_u16 = 0
				}
				IcuHdl_PulseDataBak_st[1] {
					highPulse_u16 = 0
					lowPulse_u16 = 0
				}
				IcuHdl_PulseDataBak_st[2] {
					highPulse_u16 = 0
					lowPulse_u16 = 0
				}
			}
			$calltrace {
				*** Ignore Call Trace ***
			}
		}
	}
	$testcase 3 {
